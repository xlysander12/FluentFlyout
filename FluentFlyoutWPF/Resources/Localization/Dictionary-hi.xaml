    <system:String x:Key="EnableInsertKeyTitle">कुंजी पॉपअप सम्मिलित करें सक्षम करें</system:String>
    <system:String x:Key="EnableInsertKeyDescription">यह निर्धारित करता है कि इन्सर्ट/ओवरराइट दबाने पर फ़्लाईआउट दिखाई देगा या नहीं</system:String>
    <system:String x:Key="SystemSettingsTitle">प्रणाली</system:String>
    <system:String x:Key="LaunchOnStartupTitle">स्टार्टअप पर लॉन्च करें</system:String>
