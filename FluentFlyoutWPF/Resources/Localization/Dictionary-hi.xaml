    <system:String x:Key="TaskbarWidgetCustomizationTitle">टास्कबार विजेट</system:String>
    <system:String x:Key="TaskbarWidgetDescription">एक कॉम्पैक्ट, अंतर्निर्मित विजेट जो आपके मीडिया तक त्वरित पहुंच के लिए सीधे आपके विंडोज टास्कबार पर रहता है। संपूर्ण मीडिया फ़्लाईआउट का विस्तार करने के लिए विजेट पर क्लिक करें।</system:String>
    <system:String x:Key="TaskbarWidgetEnabledTitle">टास्कबार विजेट सक्षम करें</system:String>
    <system:String x:Key="TaskbarWidgetEnabledDescription">टास्कबार पर एक कॉम्पैक्ट मीडिया विजेट दिखाएं</system:String>
    <system:String x:Key="TaskbarWidgetVisualIssuesWarning">यदि आप दृश्य समस्याओं का अनुभव करते हैं तो नीचे दिए गए विकल्पों को कॉन्फ़िगर करें।</system:String>
    <system:String x:Key="TaskbarWidgetPaddingTitle">विंडोज़ विजेट बटन के लिए स्वचालित पैडिंग</system:String>
    <system:String x:Key="TaskbarWidgetPaddingDescription">यदि आपके पास Windows विजेट सक्षम है तो इस सुविधा को चालू करें</system:String>
    <system:String x:Key="PremiumFeatureTitle">प्रीमियम सुविधा</system:String>
    <system:String x:Key="PremiumFeatureDescription" xml:space="preserve">आपका एक बार का योगदान FluentFlyout को चालू और अपडेटेड रखने में मेरी मदद करता है। इससे सभी प्रीमियम कस्टमाइज़ेशन फ़ीचर तुरंत और हमेशा के लिए अनलॉक हो जाते हैं।

ध्यान दें: एक ओपन-सोर्स प्रोजेक्ट होने के नाते, ये फ़ीचर GitHub पर मैनुअल इंस्टॉलर के ज़रिए मुफ़्त में भी उपलब्ध हैं। बस इसमें एक बात का ध्यान रखना होगा कि अपडेट और इंस्टॉलेशन मैनुअली करने होंगे।</system:String>
