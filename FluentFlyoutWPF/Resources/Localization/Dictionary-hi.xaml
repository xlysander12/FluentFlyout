    <system:String x:Key="RepeatButtonTitle">रीपीट(दोहराएँ) बटन*</system:String>
    <system:String x:Key="RepeatButtonDescription">सभी को दोहराने या केवल एक को दोहराने का विकल्प चुनें, इससे फ्लाईआउट की चौड़ाई बढ़ जाती है</system:String>
    <system:String x:Key="ShuffleButtonTitle">शफल बटन*</system:String>
    <system:String x:Key="ShuffleButtonDescription">फ्लाईआउट की चौड़ाई बढ़ाता है</system:String>
    <system:String x:Key="ShowSeekbarTitle">सीकबार दिखाएँ*</system:String>
    <system:String x:Key="ShowSeekbarDescription">यदि प्लेयर इसे सपोर्ट करता है तो एक इंटरैक्टेबल सीकबार अपने आप प्रदर्शित हो जाएगी</system:String>
    <system:String x:Key="UnsupportedControlsWarning">*कुछ ब्राउज़र/प्लेयर रिपीट, शफल और सीकबार कंट्रोल को सपोर्ट नहीं करते हैं।</system:String>
    <system:String x:Key="PauseOtherMediaTitle">अन्य मीडिया को स्वचालित रूप से रोकें</system:String>
    <system:String x:Key="PauseOtherMediaDescription">जब आप खेलते हैं या नए मीडिया पर ध्यान केंद्रित करते हैं, तो अन्य सक्रिय सत्र स्वचालित रूप से रुक जाते हैं</system:String>
    <system:String x:Key="NextUpCustomizationTitle">नेक्स्ट अप फ्लाईआउट</system:String>
    <system:String x:Key="NextUpDescription" xml:space="preserve">जब कोई गीत/वीडियो समाप्त होता है तो फ़्लाईआउट दिखाता है कि आगे क्या है। केवल तभी दिखाई देता है जब अगला आइटम स्वचालित रूप से चलता है, यदि अगला/पिछला मैन्युअल रूप से दबाया जाता है, तो इसके बजाय मुख्य फ्लाईआउट दिखाई देता है।</system:String>
    <system:String x:Key="EnableNextUpTitle">नेक्स्ट अप फ्लाईआउट सक्षम करें</system:String>
    <system:String x:Key="EnableNextUpDescription">जब कोई गीत/वीडियो समाप्त होता है तो दिखाता है कि आगे क्या है</system:String>
    <system:String x:Key="NextUpStayDurationTitle">अगले ऊपर रहने की अवधि</system:String>
    <system:String x:Key="NextUpStayDurationDescription">(डिफ़ॉल्ट: 2000 एमएस)</system:String>
    <system:String x:Key="LockKeysCustomizationTitle">लॉक कीज़ फ़्लाईआउट</system:String>
    <system:String x:Key="LockKeysDescription" xml:space="preserve">एक नज़र में अपने ताले की कुंजी की स्थिति जांचें। कैप्स लॉक, न्यूम लॉक या स्क्रॉल लॉक दबाने के बाद दिखाई देता है। बिना लॉक कुंजी संकेतक वाले लैपटॉप/कीबोर्ड के लिए सुविधाजनक।</system:String>
    <system:String x:Key="EnableLockKeysTitle">लॉक कुंजी फ़्लाईआउट सक्षम करें</system:String>
    <system:String x:Key="EnableLockKeysDescription">प्रदर्शित करता है कि निर्दिष्ट लॉक कुंजी चालू है या बंद है</system:String>
    <system:String x:Key="LockKeysStayDurationTitle">ताले की चाबियाँ रहने की अवधि</system:String>
    <system:String x:Key="LockKeysBoldUITitle">बोल्ड प्रतीक और फ़ॉन्ट</system:String>
